datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String @id @default(uuid())
  name             String
  email            String @unique
  passwordHash     String
  role             String @default("BUYER") // BUYER, SELLER, ADMIN
  subscriptionTier String @default("FREE") // FREE, PRO, PREMIUM
  reputationScore  Int    @default(0)

  // Seller Payment Profile
  bankAccount String?
  address     String?

  // Relations
  products       Product[]
  offersAsBuyer  Offer[]   @relation("BuyerOffers")
  offersAsSeller Offer[]   @relation("SellerOffers")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id                    String @id @default(uuid())
  sellerId              String
  title                 String
  description           String
  category              String @default("OTHER") // ELECTRONICS, CLOTHING, HOME, TOYS, OTHER
  images                String // comma-separated URLs or JSON
  publicPrice           Float
  autoAcceptFloorPrice  Float
  autoCounterFloorPrice Float
  inventoryCount        Int    @default(1)

  seller User    @relation(fields: [sellerId], references: [id])
  offers Offer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Offer {
  id          String    @id @default(uuid())
  productId   String
  buyerId     String
  sellerId    String
  offerAmount Float
  status      String    @default("PENDING") // PENDING, AUTO_COUNTERED, ACCEPTED, REJECTED, EXPIRED, PAID
  expiresAt   DateTime?
  history     String? // JSON string

  product     Product      @relation(fields: [productId], references: [id])
  buyer       User         @relation("BuyerOffers", fields: [buyerId], references: [id])
  seller      User         @relation("SellerOffers", fields: [sellerId], references: [id])
  transaction Transaction?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id            String @id @default(uuid())
  offerId       String @unique
  amountPaid    Float
  paymentStatus String @default("PROCESSING") // PROCESSING, SUCCESS, FAILED

  offer Offer @relation(fields: [offerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
